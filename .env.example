# ---------------------------------------------------------------------------
# Roark — required by observe_session itself
# ---------------------------------------------------------------------------

# Roark API key — create one on the API keys page in your Roark project.
# This is the only Roark setting you need; the helper knows its own endpoints.
ROARK_API_KEY=rk_live_replace_me

# Optional kill switch — set to false to make observe_session a no-op:
# ROARK_OBSERVABILITY_ENABLED=true

# ---------------------------------------------------------------------------
# Services — only needed to run the example agent (not by the library itself).
# Swap providers freely in your own agent; observe_session is provider-agnostic.
# See examples/.env.example for the full runnable-example configuration.
# ---------------------------------------------------------------------------

OPENAI_API_KEY=
SPEECHMATICS_API_KEY=
CARTESIA_API_KEY=

# Self-hosted LiveKit server — only needed for `agent.py dev` (not `console`).
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_at_least_32_chars_long
