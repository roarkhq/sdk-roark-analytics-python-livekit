# Copy to `.env` and fill in. Then: `set -a; source .env; set +a`

# --- AI providers used by the agent -------------------------------------
OPENAI_API_KEY=
SPEECHMATICS_API_KEY=
CARTESIA_API_KEY=

# --- Roark analytics ----------------------------------------------------
ROARK_API_KEY=rk_live_...
# Optional kill switch — set to false to make observe_session a no-op:
# ROARK_OBSERVABILITY_ENABLED=true

# --- Self-hosted LiveKit server (only needed for `python agent.py dev`) --
# Not used by `python agent.py console`.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_at_least_32_chars_long
